      <div class="card">
        <h3>Emergency Contacts</h3>
        <p>Out-of-hours and emergency contact details.</p>
        <a href="#">Emergency info</a>
      </div>

    </div>
  </section>

</main>

<footer>
  <p>© Alternative Approach | Internal use only</p>
</footer>

</body>
</html>
